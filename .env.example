# githost-mcp environment variables
# Copy to .env or source before running. All tokens are placeholders.

# Agent attribution (required — set per launcher)
AGENT_ID=dev

# Repo write allowlist (required for write operations)
ALLOWED_REPO_ROOTS=/home/user/repos/personal,/home/user/repos/work

# Audit integrity (required — generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
AUDIT_SIGNING_KEY=<generate-with-secrets.token_hex-32>

# Logging
LOG_LEVEL=INFO
LOG_FILE=/opt/appdata/githost-mcp/logs/githost-mcp.log
AUDIT_LOG_FILE=/opt/appdata/githost-mcp/audit/githost.jsonl
AUDIT_LOG_MAX_BYTES=10485760
AUDIT_LOG_BACKUP_COUNT=5

# GitHub (required for GitHub tools)
GITHUB_TOKEN=<your-github-pat-with-repo-scope>
GITHUB_OWNER=<your-github-username-or-org>

# Gitea (required for Gitea tools)
GITEA_URL=https://gitea.example.com
GITEA_TOKEN=<your-gitea-pat>
GITEA_OWNER=<your-gitea-username>

# GitLab (required for GitLab tools)
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=<your-gitlab-pat>

# Registry (required for publish tools)
PYPI_TOKEN=<your-pypi-api-token>
PYPI_TEST_TOKEN=<your-testpypi-api-token>
NPM_TOKEN=<your-npm-automation-token>

# Woodpecker CI (optional)
WOODPECKER_URL=https://ci.example.com
WOODPECKER_TOKEN=<your-woodpecker-pat>

# Git commit signing (optional)
GIT_SIGNING_KEY=

# OTEL telemetry (optional — activate by setting endpoint)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_SERVICE_NAME=githost-mcp

# Loki log push (optional — activate by setting URL)
LOKI_URL=
LOKI_LABELS=app=githost-mcp

# Prometheus scrape endpoint (optional — activate by setting port)
METRICS_PORT=

# NATS publishing (optional — activate by setting URL)
NATS_URL=
NATS_SUBJECT_PREFIX=githost
